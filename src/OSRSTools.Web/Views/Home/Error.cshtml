@model OSRSTools.Web.ViewModels.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="text-center" style="padding: 60px 20px;">
    <h1 class="text-danger">Something went wrong</h1>
    <p>An unexpected error occurred while processing your request.</p>

    @if (Model?.ShowRequestId ?? false)
    {
        <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }

    <a href="/" class="btn btn-primary mt-3">Return to Dashboard</a>
</div>
