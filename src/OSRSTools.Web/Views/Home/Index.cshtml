@model OSRSTools.Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h4 class="mb-4">Dashboard</h4>

<div class="row">
    <!-- High Alching Summary — Carousel -->
    <div class="col-lg-3 col-md-6">
        <div class="dashboard-card carousel-card">
            <h5><i class="bi bi-magic me-2"></i>High Alching</h5>
            @if (Model.TopHighAlchItems.Any())
            {
                <div class="carousel-container">
                    <button class="carousel-arrow carousel-prev" id="alchPrev" title="Previous item">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <div class="carousel-content">
                        <div class="stat-value profit-positive" id="alchItemName">--</div>
                        <div class="stat-label" id="alchItemProfit">--</div>
                        <div class="stat-label" id="alchItemRoi">--</div>
                    </div>
                    <button class="carousel-arrow carousel-next" id="alchNext" title="Next item">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
                <div class="carousel-dots" id="alchDots"></div>
            }
            else
            {
                <div class="stat-value">--</div>
                <div class="stat-label">Top profit/cast</div>
            }
        </div>
    </div>

    <!-- Flipping Summary -->
    <div class="col-lg-3 col-md-6">
        <div class="dashboard-card">
            <h5><i class="bi bi-arrow-left-right me-2"></i>Flipping</h5>
            <div class="stat-value">--</div>
            <div class="stat-label">Top GP/hr</div>
        </div>
    </div>

    <!-- Smithing Summary -->
    <div class="col-lg-3 col-md-6">
        <div class="dashboard-card">
            <h5><i class="bi bi-hammer me-2"></i>Smithing</h5>
            <div class="stat-value">--</div>
            <div class="stat-label">Best profit/bar</div>
        </div>
    </div>

    <!-- Herblore Summary -->
    <div class="col-lg-3 col-md-6">
        <div class="dashboard-card">
            <h5><i class="bi bi-flower1 me-2"></i>Herblore</h5>
            <div class="stat-value">--</div>
            <div class="stat-label">Best profit/herb</div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-12">
        <div class="dashboard-card">
            <h5><i class="bi bi-info-circle me-2"></i>Getting Started</h5>
            <p class="text-secondary mb-0">
                Welcome to OSRS Profit Calculator V2. Select a calculator from the sidebar to explore profitable items.
                Data is synced from the OSRS Wiki Real-Time Prices API.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @if (Model.TopHighAlchItems.Any())
    {
        <script>
            var topAlchItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopHighAlchItems, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
        </script>
        <script src="~/js/dashboard.js"></script>
    }
}
