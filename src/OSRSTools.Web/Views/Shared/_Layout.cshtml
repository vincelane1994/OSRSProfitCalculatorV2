<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OSRS Profit Calculator</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Top Header Bar -->
    <header class="top-header">
        <div class="header-left">
            <button class="sidebar-toggle" id="sidebarToggle" title="Toggle Sidebar">
                <i class="bi bi-list"></i>
            </button>
            <span class="header-brand">OSRS Profit Calculator</span>
        </div>
        <div class="header-center">
            <span class="sync-status" id="syncStatus">
                <i class="bi bi-clock-history"></i>
                <span>Last sync: --</span>
            </span>
        </div>
        <div class="header-right">
            <button class="btn btn-outline-light btn-sm" disabled title="Coming soon">
                <i class="bi bi-person"></i> Sign In
            </button>
        </div>
    </header>

    <!-- Sidebar Navigation -->
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-content">
            <!-- Profit Calculators Category -->
            <div class="sidebar-category">
                <button class="category-toggle" data-bs-toggle="collapse" data-bs-target="#calcMenu" aria-expanded="true">
                    <i class="bi bi-calculator"></i>
                    <span class="nav-label">Profit Calculators</span>
                    <i class="bi bi-chevron-down category-arrow"></i>
                </button>
                <div class="collapse show" id="calcMenu">
                    <ul class="sidebar-nav">
                        <li>
                            <a asp-controller="HighAlching" asp-action="Index" class="nav-link" title="High Alching">
                                <i class="bi bi-magic"></i>
                                <span class="nav-label">High Alching</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Flipping" asp-action="Index" class="nav-link" title="Flipping">
                                <i class="bi bi-arrow-left-right"></i>
                                <span class="nav-label">Flipping</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Smithing" asp-action="Index" class="nav-link" title="Smithing">
                                <i class="bi bi-hammer"></i>
                                <span class="nav-label">Smithing</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Herblore" asp-action="Index" class="nav-link" title="Herblore">
                                <i class="bi bi-flower1"></i>
                                <span class="nav-label">Herblore</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Reports Category -->
            <div class="sidebar-category">
                <button class="category-toggle" data-bs-toggle="collapse" data-bs-target="#reportsMenu" aria-expanded="true">
                    <i class="bi bi-bar-chart-line"></i>
                    <span class="nav-label">Reports</span>
                    <i class="bi bi-chevron-down category-arrow"></i>
                </button>
                <div class="collapse show" id="reportsMenu">
                    <ul class="sidebar-nav">
                        <li>
                            <a asp-controller="Home" asp-action="Index" class="nav-link" title="Dashboard">
                                <i class="bi bi-speedometer2"></i>
                                <span class="nav-label">Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Report" asp-action="Index" class="nav-link" title="Export">
                                <i class="bi bi-download"></i>
                                <span class="nav-label">Export</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="main-content" id="mainContent">
        <div class="container-fluid p-4">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/sidebar.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
