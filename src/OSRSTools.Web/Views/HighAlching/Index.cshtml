@model OSRSTools.Web.ViewModels.HighAlchViewModel

@{
    ViewData["Title"] = "High Alching";
}

<h4 class="mb-4"><i class="bi bi-magic me-2"></i>High Alching Calculator</h4>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
    </div>
}

<!-- Summary Cards -->
<div class="row mb-3">
    <div class="col-md-4">
        <div class="dashboard-card">
            <div class="stat-label">Total Items</div>
            <div class="stat-value" id="totalItemsDisplay">@Model.TotalItems</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card">
            <div class="stat-label">Profitable Items</div>
            <div class="stat-value profit-positive" id="profitableItemsDisplay">@Model.ProfitableItems</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="dashboard-card">
            <div class="stat-label">Showing</div>
            <div class="stat-value" id="showingCount">@Model.TotalItems</div>
        </div>
    </div>
</div>

<!-- Filter Panel -->
<div class="filter-panel">
    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label for="filterMembers">Members</label>
            <select id="filterMembers" class="form-select form-select-sm" onchange="applyFilters()">
                <option value="all">All</option>
                <option value="members">Members Only</option>
                <option value="f2p">F2P Only</option>
            </select>
        </div>
        <div class="col-md-2">
            <label for="filterMinProfit">Min Profit</label>
            <input type="number" id="filterMinProfit" class="form-control form-control-sm" value="100" onchange="applyFilters()" />
        </div>
        <div class="col-md-2">
            <label for="filterMaxBuyPrice">Max Buy Price</label>
            <input type="number" id="filterMaxBuyPrice" class="form-control form-control-sm" placeholder="No limit" onchange="applyFilters()" />
        </div>
        <div class="col-md-2">
            <label for="filterMinVolume">Min Volume</label>
            <input type="number" id="filterMinVolume" class="form-control form-control-sm" placeholder="No limit" onchange="applyFilters()" />
        </div>
        <div class="col-md-2">
            <label for="filterMaxInvestment">Max Investment</label>
            <input type="number" id="filterMaxInvestment" class="form-control form-control-sm" value="1000000" onchange="applyFilters()" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-sm btn-outline-warning w-100" onclick="resetFilters()">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
            </button>
        </div>
    </div>
</div>

<!-- Data Table -->
<div class="dashboard-card p-0" style="overflow-x: auto;">
    <table class="data-table" id="alchTable">
        <thead>
            <tr>
                <th onclick="sortTable('name')">Name <i class="bi bi-chevron-expand"></i></th>
                <th onclick="sortTable('buyPrice')">Buy Price <i class="bi bi-chevron-expand"></i></th>
                <th onclick="sortTable('highAlchValue')">Alch Value <i class="bi bi-chevron-expand"></i></th>
                <th onclick="sortTable('natureRuneCost')">Nature Rune <i class="bi bi-chevron-expand"></i></th>
                <th onclick="sortTable('profit')">Profit <i class="bi bi-chevron-expand"></i></th>
                <th onclick="sortTable('roiPercent')">ROI% <i class="bi bi-chevron-expand"></i></th>
                <th onclick="sortTable('volume24Hr')">Volume 24h <i class="bi bi-chevron-expand"></i></th>
            </tr>
        </thead>
        <tbody id="alchTableBody">
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        var items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
    </script>
    <script src="~/js/highalch-filter.js"></script>
}
